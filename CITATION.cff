    given-names: "Rolando"
    orcid: "https://orcid.org/0009-0005-4896-1112"
    affiliation: "Hermes Labs"
license: Apache-2.0
repository-code: "https://github.com/hermes-labs-ai/zer0lint"
keywords:
  - "AI reliability"
  - "AI assurance"
  - "memory extraction"
  - "mem0"
  - "agent memory"
  - "verification by effect"
references:
